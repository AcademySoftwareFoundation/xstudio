@echo off
REM Dev-only launcher for xstudio.exe from the build tree.
REM Adds Qt's bin directory to PATH so Qt DLLs resolve without needing
REM an install or windeployqt run. Generated by CMake; do not edit.

set "PATH=@_qt_bin_dir@;%~dp0vcpkg_installed\x64-windows\bin;%~dp0bin;%PATH%"
set "XSTUDIO_ROOT=%~dp0bin"
set "XSTUDIO_PLUGIN_PATH=%~dp0share\xstudio\plugin"
set "XSTUDIO_PYTHONHOME=%~dp0vcpkg_installed\x64-windows\tools\python3"
set "PYTHONPATH=%~dp0bin\python\lib\python3.11\site-packages;%PYTHONPATH%"
"%~dp0bin\xstudio.exe" %*
